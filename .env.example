# Copy to .env and fill in values for your deployment.
# The .env file is gitignored — never commit real endpoints.

# Port exposed on the host for the web UI
APP_PORT=8500

# OCR model endpoints — semicolon-separated list of:
#   DisplayName=BASE_URL
#
# vLLM endpoints end in /v1, Docling endpoints do not.
# Any model whose /health check fails at startup is hidden from the UI,
# so you can list only the models you actually run.
#
# Examples (replace with your own host/ports):
#   LightOnOCR-2-1B=http://vllm-lighton:8000/v1
#   GLM-OCR=http://vllm-glm:8000/v1
#   OlmOCR2=http://vllm-olmocr:8000/v1
#   Qwen35-9B=http://vllm-qwen9b:8000/v1
#   Qwen35-122B=http://vllm-qwen122b:8000/v1
#   Qwen3.6-35B=http://vllm-qwen36:8000/v1
#   Gemma4-26B=http://vllm-gemma4:8000/v1
#   Chandra=http://vllm-chandra:8000/v1
#   Docling=http://docling:5001
#   Docling-VLM=http://docling:5001
# The -FS variants reuse their base model's endpoint and strip running headers/footers
# via Docling (need DOCLING_URL below):
#   Qwen3.6-35B-FS=http://vllm-qwen36:8000/v1
#   Qwen35-9B-FS=http://vllm-qwen9b:8000/v1
#   Qwen35-122B-FS=http://vllm-qwen122b:8000/v1
OCR_MODELS=LightOnOCR-2-1B=http://vllm:8000/v1

# Required only if you expose Docling-VLM above.
# Full chat-completions URL of the VLM backend Docling should call.
DOCLING_VLM_URL=
DOCLING_VLM_MODEL=cyankiwi/Qwen3.5-35B-A3B-AWQ-4bit

# Required only for the Qwen3.6-35B-FS furniture-strip model.
# Docling Serve base URL used for layout-based header/footer removal (reuse your
# Docling endpoint; no serializer patch needed).
DOCLING_URL=
