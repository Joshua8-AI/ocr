# AgentMail (optional - if not set, email field is hidden from UI)
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=

# HuggingFace (optional, only if model is gated)
HUGGING_FACE_HUB_TOKEN=

# App base URL for download links in emails
APP_BASE_URL=http://localhost:8200

# OCR Models - semicolon-separated list of DisplayName=vllm_url
# If not set, defaults to single model: LightOnOCR-2-1B=http://vllm:8000/v1
# Example with multiple models (each needs its own vLLM container):
# OCR_MODELS=LightOnOCR-2-1B=http://vllm:8000/v1;Qwen2-VL-7B=http://vllm2:8000/v1
OCR_MODELS=LightOnOCR-2-1B=http://vllm:8000/v1
